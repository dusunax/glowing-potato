{
  "extends": "@glowing-potato/tsconfig/react-app.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",

    /* Path aliases */
    "paths": {
      "@glowing-potato/ui": ["../../packages/ui/src/index.ts"],
      "@glowing-potato/ui/*": ["../../packages/ui/src/*"],
      "@glowing-potato/theme": ["../../packages/theme/src/index.ts"],
      "@glowing-potato/theme/*": ["../../packages/theme/src/*"]
    }
  },
  "include": ["src", "../../packages/ui/src", "../../packages/theme/src"]
}
